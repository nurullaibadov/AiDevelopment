    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UserSecretsId>aidevapi-secrets-001</UserSecretsId>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.10" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AIDevAPI.Application\AIDevAPI.Application.csproj" />
    <ProjectReference Include="..\AIDevAPI.Infrastructure\AIDevAPI.Infrastructure.csproj" />
  </ItemGroup>

</Project>
